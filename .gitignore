## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# Mac
.DS_Store

# Database
*.db
*.mdf
*.ldf
BeDemo.Api/data/

# HTTPS certificates (development only)
BeDemo.Api/https/*.pem
BeDemo.Api/https/*.key
BeDemo.Api/https/*.pfx
!BeDemo.Api/https/.gitkeep

# Environment variables
.env
.env.local
.env.*.local

# Uploaded media (created at runtime; do not commit)
BeDemo.Api/wwwroot/uploads/

# Docker
.docker/

# User secrets
secrets.json

# Node (Husky / commitlint only)
node_modules/
